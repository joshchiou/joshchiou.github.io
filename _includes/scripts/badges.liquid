{% if site.enable_publication_badges.altmetric %}
  <script async src="https://d1bxh8uas1mnw7.cloudfront.net/assets/embed.js"></script>
  <script>
    // Altmetric's embed.js generates deprecated details.php?domain=...&citation_id=... URLs.
    // Rewrite them to the canonical details/<id> format.
    // For 0-score badges (no citation_id), fall back to the DOI resolver.
    (function () {
      function fixAltmetricLinks() {
        document.querySelectorAll('.altmetric-embed a[href*="altmetric.com/details"]').forEach(function (a) {
          var citationMatch = a.href.match(/[?&]citation_id=(\d+)/);
          if (citationMatch) {
            a.href = 'https://www.altmetric.com/details/' + citationMatch[1];
            return;
          }
          // 0-score papers have no citation_id — send to DOI resolver instead
          var doiMatch = a.href.match(/[?&]doi=([^&]+)/);
          if (doiMatch) {
            a.href = 'https://doi.org/' + decodeURIComponent(doiMatch[1]);
          }
        });
      }

      // MutationObserver handles badges inserted after this script runs (embed.js is async)
      var observer = new MutationObserver(fixAltmetricLinks);
      document.addEventListener('DOMContentLoaded', function () {
        observer.observe(document.body, { childList: true, subtree: true });
        fixAltmetricLinks();
      });
      // Fallback sweep after full page load
      window.addEventListener('load', fixAltmetricLinks);
    })();
  </script>
{% endif %}
{% if site.enable_publication_badges.dimensions %}
  <script async src="https://badge.dimensions.ai/badge.js"></script>
{% endif %}
